{
  "name": "allo",
  "version": "2.0.0",
  "description": "allo Monorepo - Frontend and Backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "@oxyhq/bloom": "^0.49.1",
    "@oxyhq/core": "^12.10.2",
    "@oxyhq/contracts": "^0.17.0",
    "@oxyhq/services": "^22.11.1",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/query-core": "5.101.2",
    "react-native-safe-area-context": "5.8.0",
    "lightningcss": "1.30.1"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "@oxyhq/bloom": "^0.49.1",
    "@oxyhq/core": "^12.10.2",
    "@oxyhq/contracts": "^0.17.0",
    "@oxyhq/services": "^22.11.1",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/query-core": "5.101.2",
    "react-native-safe-area-context": "5.8.0",
    "lightningcss": "1.30.1"
  },
  "scripts": {
    "dev": "bun run dev --filter '*'",
    "dev:frontend": "bun run --filter @allo/frontend dev",
    "dev:backend": "bun run --filter @allo/backend dev",
    "build": "bun run --filter '*' build",
    "build:shared-types": "bun run --filter @allo/shared-types build",
    "build:frontend": "bun run --filter @allo/frontend build",
    "build:backend": "bun run --filter @allo/backend build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "install:all": "bun install",
    "start:frontend": "bun run --filter @allo/frontend start",
    "start:backend": "bun run --filter @allo/backend start",
    "postinstall": "bun run build:shared-types"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "react-native-worklets": "0.10.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@oxyhq/bloom": "^0.49.1",
    "@oxyhq/contracts": "^0.17.0",
    "@oxyhq/core": "^12.10.2",
    "@oxyhq/services": "^22.11.1",
    "@react-native/js-polyfills": "^0.86.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "react-native-css": "^3.0.6"
  }
}
