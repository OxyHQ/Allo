{
  "name": "allo",
  "version": "2.0.0",
  "description": "allo Monorepo - Frontend and Backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@oxyhq/core": "2.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@tanstack/query-core": "5.101.0"
  },
  "resolutions": {
    "@oxyhq/core": "2.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@tanstack/query-core": "5.101.0"
  },
  "scripts": {
    "dev": "bun run dev --filter '*'",
    "dev:frontend": "bun run --filter @allo/frontend dev",
    "dev:backend": "bun run --filter @allo/backend dev",
    "build": "bun run --filter '*' build",
    "build:shared-types": "bun run --filter @allo/shared-types build",
    "build:frontend": "bun run --filter @allo/frontend build",
    "build:backend": "bun run --filter @allo/backend build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "install:all": "bun install",
    "start:frontend": "bun run --filter @allo/frontend start",
    "start:backend": "bun run --filter @allo/backend start",
    "postinstall": "bun run build:shared-types"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "react-native-worklets": "0.8.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@oxyhq/bloom": "^0.6.11",
    "@oxyhq/core": "2.0.0",
    "@oxyhq/services": "^8.0.0",
    "@react-native/js-polyfills": "^0.81.6",
    "@tanstack/query-async-storage-persister": "^5.100.0",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-query-persist-client": "^5.100.0",
    "react-native-css-interop": "^0.2.4",
    "react-native-worklets-core": "^1.6.3"
  }
}
