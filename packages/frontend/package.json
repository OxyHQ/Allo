{
  "name": "@allo/frontend",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "scripts": {
    "start": "expo start --reset-cache --tunnel --clear",
    "dev": "expo start --reset-cache --tunnel --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "clear-cache": "node ./scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "build-web": "expo export --platform web --output-dir dist",
    "build-web:prod": "expo export --platform web --output-dir dist",
    "test": "jest --watchAll=false --passWithNoTests",
    "lint": "expo lint",
    "clean": "rm -rf dist .expo"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|@noble|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|standard-navigation))",
      "/node_modules/react-native-reanimated/plugin/",
      "/node_modules/@react-native/babel-preset/"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    },
    "autolinking": {
      "exclude": [
        "react-native-sqlite-storage",
        "expo-blob"
      ]
    }
  },
  "dependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-dynamic-import": "^7.27.1",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@bitdrift/react-native": "^0.12.12",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@legendapp/list": "^3.3.2",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@oxyhq/bloom": "^0.34.2",
    "@oxyhq/contracts": "^0.15.0",
    "@oxyhq/core": "^12.2.0",
    "@oxyhq/expo-splash": "^0.1.0",
    "@oxyhq/services": "^22.2.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/query-async-storage-persister": "^5.101.2",
