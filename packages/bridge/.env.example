# Allo bridge connector — environment template.
# Copy to .env for local dev. NEVER commit real secret values.
# In production these are injected from SSM (see Allo CLAUDE.md).

# --- Required: the connector refuses to start without these ---

# Must be exactly "true" to enable the connector (matches the backend flag).
BRIDGE_ENABLED=true

# Shared HMAC-SHA256 secret with the Allo backend. MUST be >= 32 chars and
# IDENTICAL to the backend's BRIDGE_SHARED_SECRET. Generate: openssl rand -hex 32
BRIDGE_SHARED_SECRET=

# AES-256-GCM key material used to encrypt stored Telegram sessions at rest.
# MUST be >= 32 chars. Independent of BRIDGE_SHARED_SECRET. Rotating it makes all
# stored sessions undecryptable (users must re-link). Generate: openssl rand -hex 32
BRIDGE_SESSION_KEY=

# Base URL of the Allo backend's internal API (where events/media are POSTed).
# e.g. http://allo-backend:8080
ALLO_INTERNAL_URL=

# Mongo connection string for the connector's OWN session store. Falls back to
# MONGODB_URI if unset. The database name defaults to "allo-bridge".
BRIDGE_MONGODB_URI=

# --- Required for any Telegram login (the connector BOOTS without them, but all
#     Telegram session operations return 503 telegram_not_configured) ---

# Create an application at https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Optional ---

# Port the connector listens on. Default 8090.
BRIDGE_PORT=8090

# Mongo database name for the session store. Default "allo-bridge".
BRIDGE_DB_NAME=allo-bridge
