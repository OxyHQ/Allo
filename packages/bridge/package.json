{
  "name": "@allo/bridge",
  "version": "1.0.0",
  "description": "Allo interop bridge connector (Telegram first)",
  "license": "ISC",
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node --transpile-only src/index.ts",
    "dev": "nodemon --watch \"src/**/*.ts\" --exec ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest --runInBand --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@allo/shared-types": "workspace:*",
    "express": "^4.22.2",
    "mongoose": "^8.24.0",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/express": "*",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "jest-environment-node": "30.4.1",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
